{
  "manifest_version": 3,
  "name": "에이닷 CRM → 대시보드",
  "version": "0.4.0",
  "description": "에이닷 CRM 데이터 자동 수집 → 대표원장 대시보드",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://crm.adotenglish.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://crm.adotenglish.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://hensuuuu.github.io/adot-dashboard/*"
      ],
      "js": [
        "dashboard-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "에이닷 대시보드"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {}
}